<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si el archivo o directorio existe físicamente, servirlo directamente (ej: assets)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirigir todas las demás peticiones a index.php, pasando la ruta como parámetro 'url'
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>
